# ============================================================================
# REVIEW-ONLY TIMER TEMPLATE — DISABLED BY DEFAULT.
#
# This timer is intentionally shipped WITHOUT an [Install] section, so it
# cannot be `systemctl enable`-d until a separate, explicitly approved
# deployment step adds one (or installs it with an explicit WantedBy).
#
# Do NOT add WantedBy=timers.target here as part of this PR. Scheduling is
# a post-merge, human-approved operation.
# ============================================================================
[Unit]
Description=Timer for Polycopy specialist-evidence status monitor (REVIEW-ONLY, disabled)

[Timer]
OnBootSec=10min
OnUnitActiveSec=15min
AccuracySec=1min
Persistent=false
Unit=polycopy-specialist-evidence-status.service
