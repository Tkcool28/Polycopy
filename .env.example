# Copy to .env and fill in. Never commit real secrets.
# All values below are PLACEHOLDERS for local development.

# Broker mode: "paper" (default) or "polymarket"
# POLYCOPY_BROKER_MODE=paper

# Polymarket API base URLs (public endpoints, read-only by default)
# POLY_GAMMA_BASE_URL=https://gamma-api.polymarket.com
# POLY_CLOB_BASE_URL=https://clob.polymarket.com

# Polymarket wallet (DO NOT set in paper mode)
# POLY_COPY_PRIVATE_KEY=

# Logging level
# POLY_COPY_LOG_LEVEL=INFO

# ── Specialist-metric aggregation (PR #20, dormant by default) ─────────────
# PR #20 ships the evidence layer dormant. Set this env var to "true"
# (or flip the field default in src/polycopy/config/settings.py from
# False to True) to activate Step 5f and start writing rows to the
# wallet_specialist_aggregations table. Activation is a one-line change;
# it does NOT enable live trading, does NOT add a formula consumer,
# and does NOT touch TimeoutStartSec.
# POLYCOPY_SPECIALIST_AGGREGATIONS_ENABLED=false

# PR #20 specialist-metric aggregation cap (only consulted when the
# flag above is true). Default 50.
# POLYCOPY_SPECIALIST_AGGREGATIONS_MAX_ROWS_PER_RUN=50
