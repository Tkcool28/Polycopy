# Copy to .env and fill in. Never commit real secrets.
# All values below are PLACEHOLDERS for local development.

# Broker mode: "paper" (default) or "polymarket"
# POLYCOPY_BROKER_MODE=paper

# Polymarket API base URLs (public endpoints, read-only by default)
# POLY_GAMMA_BASE_URL=https://gamma-api.polymarket.com
# POLY_CLOB_BASE_URL=https://clob.polymarket.com

# Polymarket wallet (DO NOT set in paper mode)
# POLY_COPY_PRIVATE_KEY=

# Logging level
# POLY_COPY_LOG_LEVEL=INFO
